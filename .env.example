# --- required ---
MONGOOSE_URI=mongodb://localhost:27017/shelflife
JWT_SECRET=replace-with-a-long-random-string
PORT=3000

# --- email digest (optional) ---
# Without SMTP_HOST the daily cron still runs and logs what it *would* send,
# so you can develop without a mail server.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=ShelfLife <no-reply@shelflife.app>

# Cron expression for the digest. Default: every day at 08:00 server time.
DIGEST_CRON=0 8 * * *
